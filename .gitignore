# ===================================
# MemTracker Project .gitignore
# ===================================

# ===================================
# Environment Variables (IMPORTANT!)
# ===================================
# Never commit actual environment files with secrets
.env
.env.local
.env.*.local
.env.development
.env.production

# Keep example files (templates)
!.env.example
!.env.local.example

# ===================================
# Python / Backend
# ===================================
# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv
.ENV
backend/venv/
backend/env/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# Jupyter Notebook
.ipynb_checkpoints

# PyCharm
.idea/

# ===================================
# Node.js / Frontend
# ===================================
# Dependencies are handled by frontend/.gitignore
# But adding here for safety
node_modules/
frontend/node_modules/

# Build outputs
.next/
out/
dist/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===================================
# Database
# ===================================
# MongoDB
*.db
*.sqlite
*.sqlite3

# Database dumps
*.dump
*.sql

# ===================================
# AI Models & Weights
# ===================================
# Model files (too large for git)
*.pt
*.pth
*.onnx
*.h5
*.pkl
*.weights
*.bin

# Model checkpoints
checkpoints/
models/weights/

# Keep small example models or config
!models/**/config.yaml
!models/**/*.yaml

# ===================================
# Media & Data Files
# ===================================
# Videos (too large)
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.flv

# Images (generated or processed)
uploads/
output/
processed/
temp/
cache/

# Datasets
data/
datasets/
*.csv
*.json.gz
*.parquet

# Keep sample/example data
!data/samples/
!data/examples/

# ===================================
# Operating System Files
# ===================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ===================================
# IDEs & Editors
# ===================================
# VS Code
.vscode/
*.code-workspace
.history/

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ===================================
# Build & Testing
# ===================================
# Coverage reports
coverage/
.nyc_output

# Test results
test-results/
screenshots/

# ===================================
# Logs & Monitoring
# ===================================
# Application logs
logs/
*.log
combined.log
error.log
access.log

# PM2
.pm2/

# ===================================
# Docker (if added later)
# ===================================
# docker-compose.override.yml

# ===================================
# Temporary Files
# ===================================
*.tmp
*.temp
*.bak
*.swp
*.swo
.cache/
.tmp/

# ===================================
# Security & Secrets
# ===================================
# API keys, credentials, certificates
*.pem
*.key
*.crt
*.cer
*.pfx
secrets.json
credentials.json

# ===================================
# Documentation Builds
# ===================================
docs/_build/
site/

# ===================================
# Misc
# ===================================
.turbo
.vercel

