# ==================== DATABASE CONFIGURATION ====================
MONGO_URI=mongodb://localhost:27017/
SECRET_KEY=your-secret-key-here

# ==================== MODEL SELECTION ====================
# Choose which model types to use
DETECTOR_TYPE=yolo
TRACKER_TYPE=deepsort
ACTIVITY_TYPE=zero_shot

# ==================== YOLO DETECTOR CONFIG ====================
# Available models: yolov8n.pt, yolov8s.pt, yolov8m.pt, yolov8l.pt, yolov8x.pt
# YOLO11: yolo11n.pt, yolo11s.pt, yolo11m.pt, yolo11l.pt, yolo11x.pt
# Or path to your custom model: models/my_custom_yolo.pt
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_TARGET_CLASSES=person

# ==================== DEEPSORT TRACKER CONFIG ====================
DEEPSORT_MAX_AGE=30
DEEPSORT_N_INIT=3
DEEPSORT_NMS_OVERLAP=0.3
DEEPSORT_MAX_COSINE_DIST=0.4
DEEPSORT_NN_BUDGET=None
DEEPSORT_EMBEDDER=mobilenet
DEEPSORT_HALF=True
DEEPSORT_BGR=True

# ==================== ACTIVITY RECOGNITION CONFIG ====================
# CLIP models: ViT-B-32, ViT-B-16, ViT-L-14, RN50
CLIP_MODEL_NAME=ViT-B-32
CLIP_DEVICE=cpu

# Comma-separated list of activities to recognize
ACTIVITY_LABELS=walking,sitting,standing,running,falling,phone usage

# ==================== PIPELINE CONFIG ====================
PROCESS_EVERY_N_FRAMES=1
ENABLE_ACTIVITY_RECOGNITION=True
LOG_TO_MONGODB=True

# ==================== RTSP STREAM CONFIG ====================
# Comma-separated RTSP URLs
RTSP_URLS=
RTSP_BUFFER_SIZE=1
